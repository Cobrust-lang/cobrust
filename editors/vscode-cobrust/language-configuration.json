{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "f\"", "close": "\"", "notIn": ["string"] },
    { "open": "r\"", "close": "\"", "notIn": ["string"] },
    { "open": "b\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "offSide": true,
    "markers": {
      "start": "^\\s*#\\s*region\\b",
      "end": "^\\s*#\\s*endregion\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|class|struct|enum|trait|impl|if|elif|else|for|while|match|case|try|except|finally|with)\\b.*:\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(elif|else|except|finally|case)\\b.*:\\s*(#.*)?$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(fn|class|struct|enum|trait|impl|if|elif|else|for|while|match|case|try|except|finally|with)\\b.*:\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*return\\b.*$",
      "action": { "indent": "outdent" }
    }
  ],
  "wordPattern": "(-?\\d+(?:\\.\\d+)?)|([A-Za-z_][A-Za-z0-9_]*)"
}
