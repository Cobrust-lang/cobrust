# Rust build output
/target
**/*.rs.bk

# Cobrust per-package build output — `cobrust build` emits under
# <workspace>/target/cobrust/ when invoked in package mode (M12).
examples/*/target/

# Cobrust workspace artifacts
/.cobrust
# Translator integration tests may write transient .cobrust under any
# subdirectory (cache + ledger). Ignore everywhere.
**/.cobrust
*.log

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local-only env files
.env
.env.local
.env.*.local

# Python bytecode caches (corpus harness scratch)
__pycache__/
*.pyc
