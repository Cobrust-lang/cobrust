# Rust build output
/target
**/*.rs.bk

# Cobrust per-package build output — `cobrust build` emits under
# <workspace>/target/cobrust/ when invoked in package mode (M12).
examples/*/target/

# Per-crate build artifacts (e.g. crates/cobrust-cli/target/cobrust/v02_clean.o
# emitted by cli_verifier_exit_corpus integration test).
crates/*/target/

# Cobrust workspace artifacts
/.cobrust
# Translator integration tests may write transient .cobrust under any
# subdirectory (cache + ledger). Ignore everywhere.
**/.cobrust
*.log

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local-only env files
.env
.env.local
.env.*.local

# Python bytecode caches (corpus harness scratch)
__pycache__/
*.pyc

# Claude Code agent transcript worktrees (CTO 2026-05-16 — leaked once
# via `git add -A` in the f64 fmt-stamp 46b3d02; gitignored to prevent
# recurrence).
.claude/
