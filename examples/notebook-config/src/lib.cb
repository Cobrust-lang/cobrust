# cobrust-notebook-config — M12 notebook helper module.
#
# This file plays the role of a translated-library library entry point
# for the M12 notebook example. The real `cobrust-tomli` translation
# carries a Rust-side `lib.rs`; this Cobrust-side `lib.cb` is the
# Cobrust-tier counterpart that the M12 package format expects.
#
# Surface (binding for the notebook example):
#
# - `print_banner()` — emits the helper's identity banner.
# - `print_version()` — emits the helper's version string.
# - `print_section_header(name: str)` — prefixed banner line.
# - `print_known_section_*()` — helper-named section banners.
# - `print_boot_*()` — boot diagnostics.
# - `validate_*()` — placeholder validation API.
# - `emit_*_separator()` — section separators.
# - `identify_self_*()` — identity helpers.
#
# Implementation note: at M11 codegen scope only literal-string
# `print(...)` callsites lower end-to-end. M12 does not extend that
# scope (M11 followups for Aggregate / Ref / Cast / for-protocol /
# f-string materialization are tracked under ADR-0025 §"Codegen
# amendments" and stay deferred per ADR-0026 §"Cross-milestone
# conflict guard"). Each helper here therefore lowers to a sequence
# of literal `print(...)` calls.
#
# Why this matters: the notebook example demonstrates the M12 package
# format end-to-end (manifest parse + dep resolve + lockfile + content-
# addressed cache + multi-module orchestration) WITHOUT requiring the
# stdlib HIR-tier amendments that are out of M12 scope.

# --- Public surface — banners ----------------------------------------

fn print_banner() -> i64:
    print("notebook-config: ready")
    return 0

fn print_version() -> i64:
    print("notebook-config: v0.1.0")
    return 0

fn print_section_header(name: str) -> i64:
    print("notebook-config: section header")
    return 0

# Note: at M11 codegen the `name` parameter is reserved-but-unused
# because string concatenation lowering depends on Aggregate Rvalue
# materialization (M11 followup; tracked in ADR-0025 §F). The notebook
# uses literal headers via `print_known_section_*` helpers below.

fn print_known_section_intro() -> i64:
    print("notebook-config: section [intro]")
    return 0

fn print_known_section_data() -> i64:
    print("notebook-config: section [data]")
    return 0

fn print_known_section_summary() -> i64:
    print("notebook-config: section [summary]")
    return 0

fn print_known_section_appendix_a() -> i64:
    print("notebook-config: section [appendix.a]")
    return 0

fn print_known_section_appendix_b() -> i64:
    print("notebook-config: section [appendix.b]")
    return 0

fn print_known_section_appendix_c() -> i64:
    print("notebook-config: section [appendix.c]")
    return 0

