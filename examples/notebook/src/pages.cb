# notebook/src/pages.cb — M12 notebook example.
#
# `pages` is the second of three modules in the notebook example
# (per ADR-0019 §"Definition of usable" line 3 "≥ 3 modules"). It
# carries the page-rendering helpers that drive the scripted
# transcript in `main.cb`.
#
# At M11 codegen scope, the page-rendering helpers are scripted
# literal-print sequences (M11 followups for f-string / Aggregate /
# Ref / Cast lowering remain deferred past M12 per ADR-0026's
# "smallest correct increment" rule).
#
# Public surface:
#
#   - `render_overview_page()`     — page 1 transcript.
#   - `render_registry_page()`     — page 2 transcript.
#   - `render_provenance_page()`   — page 3 transcript.
#   - `render_index_summary()`     — small TOC summary.
#   - `render_legend_block()`      — explains the M12 schema.
#   - `render_failure_block()`     — emits the failure-mode legend.
#   - `render_appendix_*()`        — appendix pages for the long form.
#
# Why this file ships even though main.cb doesn't import it:
#
# At M11 codegen, only the manifest's `[bin] path = "src/main.cb"` is
# the canonical build entry. Multi-source-file orchestration (i.e.
# `import std.io` resolving to a sibling source file plus its symbols
# being linked into the bin) is M12.x scope. Bundling the additional
# modules now satisfies the line-3 "≥ 3 modules" constraint of the
# M12 milestone and pre-warms the path so M12.x can wire `import` end-
# to-end.

# --- Pages 1..3 ------------------------------------------------------

fn render_overview_page() -> i64:
    print("pages: page 1 — what is a Cobrust package?")
    print("pages: ----------------------------------")
    print("pages: a Cobrust package is a directory with `cobrust.toml`")
    print("pages: at its root, a `[package]` table inside, and at least")
    print("pages: one of `[bin]` / `[lib]` declared.")
    print("pages: every dep listed under `[dependencies]` resolves to")
    print("pages: a content-addressed entry under ~/.cobrust/registry/.")
    print("pages: the lockfile (cobrust.lock) snapshots the resolved")
    print("pages: graph deterministically.")
    print("pages: end of page 1.")
    return 0

fn render_registry_page() -> i64:
    print("pages: page 2 — the content-addressed registry")
    print("pages: --------------------------------------")
    print("pages: every package's source tree is normalized into a")
    print("pages: deterministic tarball (sorted entries, zeroed mtime/")
    print("pages: uid/gid/uname/gname, canonical perms 0o644 / 0o755).")
    print("pages: blake3-hashed tarballs key the cache directory:")
    print("pages: ~/.cobrust/registry/blake3/<64-hex>/")
    print("pages: same input bytes → same hex → same cache dir.")
    print("pages: idempotent insertion: re-fetching a package is a")
    print("pages: no-op once the entry is cached.")
    print("pages: end of page 2.")
    return 0

fn render_provenance_page() -> i64:
    print("pages: page 3 — translated-library provenance")
    print("pages: ---------------------------------------")
    print("pages: per ADR-0007, every translated crate carries a")
    print("pages: PROVENANCE.toml under its package root. The file")
    print("pages: records the source library, its sha256, the LLM")
    print("pages: router decisions, the differential-test seeds, the")
    print("pages: divergences, and the `deterministic_id` (a blake3)")
    print("pages: of the translation output.")
    print("pages: M12 hooks this up: the pkg pipeline reads the")
    print("pages: deterministic_id at fetch time and stores it as")
    print("pages: `provenance_hash` in the lockfile, so user-crate")
    print("pages: dep graphs round-trip the chain-of-custody.")
    print("pages: end of page 3.")
    return 0

# --- Pages 4..6 (appendix) ------------------------------------------

fn render_appendix_a_resolution() -> i64:
    print("pages: appendix A — resolution algorithm")
    print("pages: ----------------------------------")
    print("pages: the M12 resolver is `max-compatible greedy`:")
    print("pages:   1. walk the dep graph DFS from the manifest's")
    print("pages:      [dependencies] (and [dev-dependencies] if")
    print("pages:      --include-dev).")
    print("pages:   2. for each unique package name in the graph,")
    print("pages:      pick the highest version satisfying every")
    print("pages:      requirement targeting that package.")
    print("pages:   3. cycle-detect via DFS-with-color; surface as")
    print("pages:      ResolutionError::Cycle.")
    print("pages:   4. emit a deterministic lockfile from the chosen")
    print("pages:      versions.")
    print("pages: end of appendix A.")
    return 0

fn render_appendix_b_lockfile() -> i64:
    print("pages: appendix B — lockfile schema")
    print("pages: -----------------------------")
    print("pages: cobrust.lock is auto-generated. Fields:")
    print("pages:   [metadata]")
    print("pages:     manifest_hash    = blake3:<hex>")
    print("pages:     lockfile_version = 1")
    print("pages:   [[package]]")
    print("pages:     name             = string")
    print("pages:     version          = string (semver)")
    print("pages:     source           = `path+file://...` | `git+...` | `registry+...`")
    print("pages:     hash             = blake3:<hex>")
    print("pages:     provenance_hash  = blake3:<hex> (optional)")
    print("pages:     dependencies     = [\"name version\", ...] sorted")
    print("pages: end of appendix B.")
    return 0

fn render_appendix_c_namespace() -> i64:
    print("pages: appendix C — namespace collision")
    print("pages: --------------------------------")
    print("pages: ADR-0024 deferred + ADR-0026 closed: option C.")
    print("pages: both M3 router config + M12 user-crate config use")
    print("pages: `cobrust.toml`; tools detect which schema by:")
    print("pages:   * pkg::Manifest::parse_str checks for [package] +")
    print("pages:     rejects [router]-only as IsRouterConfig.")
    print("pages:   * llm-router::Config::from_str does the converse.")
    print("pages: in 99% of repos a given `cobrust.toml` has only one")
    print("pages: of the two table sets, so the disjoint-tables rule")
    print("pages: is safe in practice.")
    print("pages: end of appendix C.")
    return 0

fn render_appendix_d_sources() -> i64:
    print("pages: appendix D — source kinds")
    print("pages: --------------------------")
    print("pages: M12 supports three source kinds:")
    print("pages:   * Path — `dependencies.foo = { path = \"...\" }`")
    print("pages:            cheapest; resolved relative to the")
    print("pages:            manifest's directory.")
    print("pages:   * Git  — `dependencies.foo = { git = \"...\",")
    print("pages:                                  rev = \"...\" }`")
    print("pages:            invokes the system `git` CLI.")
    print("pages:            requires `git` on PATH.")
    print("pages:   * Registry — bare-string `dependencies.foo = \"1.2\"`")
    print("pages:            or table form. M12 returns Offline unless")
    print("pages:            the entry is already cached.")
    print("pages: end of appendix D.")
    return 0

fn render_appendix_e_tarball() -> i64:
    print("pages: appendix E — tarball determinism")
    print("pages: -------------------------------")
    print("pages: when Tarball::build walks a source tree:")
    print("pages:   1. lists each directory, sorted alphabetically.")
    print("pages:   2. drops symlinks unconditionally.")
    print("pages:   3. excludes target/, .git/, .cobrust/, cobrust.lock.")
    print("pages:   4. zeroes mtime / uid / gid / uname / gname.")
    print("pages:   5. canonical perms: 0o644 (file), 0o755 (dir).")
    print("pages:   6. tar-formats with HeaderMode::Deterministic.")
    print("pages:   7. gzips with fixed level 6.")
    print("pages:   8. blake3-hashes the gzipped bytes.")
    print("pages: same source tree → identical bytes → identical hex.")
    print("pages: end of appendix E.")
    return 0

# --- Index, legend, failure block -----------------------------------

fn render_index_summary() -> i64:
    print("pages: index summary:")
    print("pages:   page 1: package format")
    print("pages:   page 2: content-addressed registry")
    print("pages:   page 3: translated-library provenance")
    print("pages:   appendix A: resolution algorithm")
    print("pages:   appendix B: lockfile schema")
    print("pages:   appendix C: namespace collision")
    print("pages:   appendix D: source kinds")
    print("pages:   appendix E: tarball determinism")
    return 0

fn render_legend_block() -> i64:
    print("pages: legend:")
    print("pages:   [package].name             — required, [a-zA-Z][a-zA-Z0-9_-]*")
    print("pages:   [package].version          — required, semver")
    print("pages:   [package].cobrust-version  — required, M12 = 0.0.1")
    print("pages:   [package].authors          — optional, array of strings")
    print("pages:   [package].license          — optional, SPDX")
    print("pages:   [package].description      — optional")
    print("pages:   [dependencies].<key>       — string semver, table path/git/registry")
    print("pages:   [dev-dependencies].<key>   — same shape")
    print("pages:   [bin]                      — single bin target (M12 single-bin scope)")
    print("pages:   [lib]                      — single lib target")
    print("pages:   [[test]]                   — test array")
    return 0

fn render_failure_block() -> i64:
    print("pages: failure modes (ADR-0026 §D):")
    print("pages:   ResolutionError::Conflict   — siblings disagree on a version")
    print("pages:   ResolutionError::Cycle      — graph has an SCC")
    print("pages:   ResolutionError::MissingPackage — registry has no entry")
    print("pages:   RegistryError::Offline      — registry source @ M12 stub")
    print("pages:   RegistryError::HashMismatch — tarball ≠ recorded hash")
    print("pages:   ManifestError::IsRouterConfig — accidentally pointed at a router config")
    print("pages:   ManifestError::NoTarget     — neither [bin] nor [lib] declared")
    print("pages:   ManifestError::ConflictingPaths — [bin].path == [lib].path")
    return 0

# --- Walkthrough sections (used by the M12.x doc-walkthrough demo) ---

fn render_walkthrough_step_1() -> i64:
    print("pages: walkthrough step 1 — `cobrust new notebook`")
    print("pages:   creates ./notebook/")
    print("pages:   creates ./notebook/cobrust.toml")
    print("pages:   creates ./notebook/src/main.cb")
    print("pages:   creates ./notebook/tests/smoke.cb")
    return 0

fn render_walkthrough_step_2() -> i64:
    print("pages: walkthrough step 2 — `cobrust add cobrust-tomli --path ../cobrust-tomli`")
    print("pages:   reads ./notebook/cobrust.toml")
    print("pages:   appends a row to [dependencies]")
    print("pages:   re-writes the file (preserving comments)")
    return 0

fn render_walkthrough_step_3() -> i64:
    print("pages: walkthrough step 3 — `cobrust build`")
    print("pages:   walks up to ./notebook/cobrust.toml")
    print("pages:   resolves ./notebook/cobrust.toml's dep graph")
    print("pages:   inserts each path-dep into the registry")
    print("pages:   emits ./notebook/cobrust.lock (deterministic)")
    print("pages:   builds [bin].path → target/cobrust/notebook")
    return 0

fn render_walkthrough_step_4() -> i64:
    print("pages: walkthrough step 4 — `cobrust test`")
    print("pages:   walks up to ./notebook/cobrust.toml")
    print("pages:   builds each [[test]] entry into a fresh exe")
    print("pages:   invokes each; pass iff exit == 0")
    print("pages:   prints scoreboard")
    return 0

fn render_walkthrough_step_5() -> i64:
    print("pages: walkthrough step 5 — repeated builds are idempotent")
    print("pages:   second `cobrust build` reuses the cached entries")
    print("pages:   second `cobrust build` re-emits the same lockfile")
    print("pages:   bytes verbatim (deterministic gate)")
    return 0

# --- Standalone smoke entry ------------------------------------------

# `main()` here is a tiny smoke entry that shipped as a pre-flight
# check during development. It's not the package's [bin] target (that
# stays main.cb); a future M12.x landing wires `import notebook.pages`
# from main.cb and removes this entry.

fn main() -> i64:
    print("pages: standalone smoke entry")
    return 0
