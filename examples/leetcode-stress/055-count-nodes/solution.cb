# LC-055 count-nodes (ADR-0047 LC-100 Tier A bucket B2).
#
# Input  (stdin): N on line 1; N lines each "val left_idx right_idx" (0-based, -1=null), root=node 0
# Output: total number of nodes in the tree
# Algorithm: N is the count directly from input; just print N

fn main() -> i64:
    let n = parse_int(input(""))
    let i: i64 = 0
    while i < n:
        let line = input("")
        i = i + 1
    print(n)
    return 0
