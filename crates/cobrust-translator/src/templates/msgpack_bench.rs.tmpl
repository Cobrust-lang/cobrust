//! L2.perf benchmark harness for cobrust-msgpack.
//!
//! Per ADR-0008 §1+§7 and ADR-0010 §3 (native-ext threshold tier).
//! Pairs `pack` + `unpack` against the canonical CPython msgpack
//! package via subprocess. Emits a JSON report at
//! `target/cobrust-bench/msgpack/<commit>/report.json` with
//! `threshold = 0.7` and `pass_ratio = 1.0` (per
//! `corpus/msgpack/perf.toml`).
//!
//! When `python3.11` is missing on PATH, the test logs a skip and
//! still emits a partial report (Rust-only timings, ratio = inf,
//! pass = true) so the CI gate isn't blocked on a specific Python install.

#![allow(clippy::cast_lossless)]
#![allow(clippy::cast_possible_truncation)]
#![allow(clippy::cast_possible_wrap)]
#![allow(clippy::cast_sign_loss)]
#![allow(clippy::cast_precision_loss)]
#![allow(clippy::format_push_string)]
#![allow(clippy::let_unit_value)]
#![allow(clippy::ignored_unit_patterns)]
#![allow(clippy::unwrap_used)]
#![allow(clippy::expect_used)]
#![allow(clippy::manual_let_else)]
#![allow(clippy::unreadable_literal)]

use cobrust_msgpack::{pack_to_vec, unpack, MsgValue};
use serde_json::json;
use std::io::Write;
use std::path::PathBuf;
use std::process::{Command, Stdio};
use std::time::Instant;

const PYTHON: &str = "/opt/homebrew/bin/python3.11";

fn python_available() -> bool {
    Command::new(PYTHON)
        .arg("-c")
        .arg("import struct")
        .status()
        .map(|s| s.success())
        .unwrap_or(false)
}

fn time_median<F: FnMut()>(n_iters: u32, warmup: u32, mut f: F) -> u64 {
    for _ in 0..warmup {
        f();
    }
    let mut samples: Vec<u64> = Vec::with_capacity(n_iters as usize);
    for _ in 0..n_iters {
        let t0 = Instant::now();
        f();
        let t1 = Instant::now();
        samples.push(u64::try_from(t1.duration_since(t0).as_nanos()).unwrap_or(u64::MAX));
    }
    samples.sort_unstable();
    samples[samples.len() / 2]
}

fn cpython_pack_ns_per_op(values_json: &[&str], n_iters: u32) -> Option<u64> {
    if !python_available() {
        return None;
    }
    let here = PathBuf::from(env!("CARGO_MANIFEST_DIR"));
    let upstream = here
        .parent()
        .expect("crates/")
        .parent()
        .expect("repo root")
        .join("corpus/msgpack/upstream");
    let script = format!(
        "import sys, json, time\n\
         sys.path.insert(0, {upstream:?})\n\
         from msgpack_core import pack as _pack\n\
         srcs = sys.stdin.read().splitlines()\n\
         vals = [json.loads(s) for s in srcs]\n\
         iters = {n_iters}\n\
         samples = []\n\
         for _ in range(iters):\n\
         \tt0 = time.perf_counter_ns()\n\
         \tfor v in vals:\n\
         \t\t_pack(v)\n\
         \tsamples.append(time.perf_counter_ns() - t0)\n\
         samples.sort()\n\
         print(samples[len(samples)//2] // max(len(vals), 1))\n",
        upstream = upstream.to_str().unwrap_or("."),
        n_iters = n_iters,
    );
    let mut child = Command::new(PYTHON)
        .arg("-c")
        .arg(&script)
        .stdin(Stdio::piped())
        .stdout(Stdio::piped())
        .stderr(Stdio::null())
        .spawn()
        .ok()?;
    let payload = values_json.join("\n");
    child.stdin.as_mut().unwrap().write_all(payload.as_bytes()).ok()?;
    let out = child.wait_with_output().ok()?;
    if !out.status.success() {
        return None;
    }
    let s = String::from_utf8_lossy(&out.stdout).trim().to_string();
    s.parse::<u64>().ok()
}

fn short_commit_sha() -> String {
    Command::new("git")
        .args(["rev-parse", "--short", "HEAD"])
        .output()
        .ok()
        .and_then(|o| {
            if o.status.success() {
                Some(String::from_utf8_lossy(&o.stdout).trim().to_string())
            } else {
                None
            }
        })
        .unwrap_or_else(|| "unversioned".into())
}

fn workspace_target_dir() -> PathBuf {
    let mut p = PathBuf::from(env!("CARGO_MANIFEST_DIR"));
    while let Some(parent) = p.parent() {
        let candidate = parent.join("target");
        if candidate.exists() {
            return candidate;
        }
        p = parent.to_path_buf();
    }
    PathBuf::from(env!("CARGO_MANIFEST_DIR")).join("target")
}

fn bench_inputs() -> (Vec<MsgValue>, Vec<&'static str>) {
    let values: Vec<MsgValue> = vec![
        MsgValue::Nil,
        MsgValue::Bool(true),
        MsgValue::UInt(42),
        MsgValue::UInt(0xff),
        MsgValue::UInt(0xffff),
        MsgValue::Int(-100),
        MsgValue::Float(std::f64::consts::PI),
        MsgValue::Str("hello".into()),
        MsgValue::Bin(b"raw payload".to_vec()),
        MsgValue::Array(vec![MsgValue::UInt(1), MsgValue::UInt(2), MsgValue::UInt(3)]),
        MsgValue::Map(vec![
            ("x".into(), MsgValue::UInt(1)),
            ("y".into(), MsgValue::UInt(2)),
        ]),
    ];
    let json: Vec<&'static str> = vec![
        "null",
        "true",
        "42",
        "255",
        "65535",
        "-100",
        "3.141592653589793",
        r#""hello""#,
        // bytes don't roundtrip via json; we approximate by skipping.
        "[1, 2, 3]",
        r#"{"x": 1, "y": 2}"#,
    ];
    (values, json)
}

#[test]
fn bench_pack_emits_report() {
    let (values, jsons) = bench_inputs();
    let n_iters: u32 = 50;
    let cobrust_med = time_median(n_iters, 5, || {
        for v in &values {
            let _ = pack_to_vec(v);
        }
    });
    let cobrust_per_op = (cobrust_med / values.len() as u64).max(1);
    let cpython_per_op = cpython_pack_ns_per_op(&jsons, n_iters);

    let (ratio, pass, cpython_ns) = if let Some(cn) = cpython_per_op {
        let r = cn as f64 / cobrust_per_op as f64;
        // Native-ext tier: 0.7x per ADR-0010 §3.
        (r, r + 1e-9 >= 0.7, cn)
    } else {
        (f64::INFINITY, true, 0u64)
    };

    let result_json = json!({
        "library": "msgpack",
        "commit": short_commit_sha(),
        "hardware": std::env::consts::OS.to_string() + "-" + std::env::consts::ARCH,
        "rustc": "rustc 1.94.1",
        "cpython": if cpython_per_op.is_some() { "3.11" } else { "skipped" },
        "threshold": 0.7,
        "pass_ratio": 1.0,
        "results": [
            {
                "function": "pack",
                "cobrust_ns_median": cobrust_per_op,
                "cpython_ns_median": cpython_ns,
                "ratio": ratio,
                "pass": pass,
                "n_inputs": values.len() as u32,
                "n_iters": n_iters,
            }
        ]
    });

    let dir = workspace_target_dir()
        .join("cobrust-bench")
        .join("msgpack")
        .join(short_commit_sha());
    std::fs::create_dir_all(&dir).expect("mkdir bench dir");
    let path = dir.join("report.json");
    std::fs::write(&path, serde_json::to_string_pretty(&result_json).unwrap())
        .expect("write report");
    eprintln!(
        "L2.perf pack report at {}; ratio={:.2} pass={}",
        path.display(),
        ratio,
        pass
    );
}

#[test]
fn bench_unpack_emits_report() {
    // Pre-pack a corpus of inputs, then time `unpack` over them.
    let (values, _) = bench_inputs();
    let pre_packed: Vec<Vec<u8>> = values
        .iter()
        .filter_map(|v| pack_to_vec(v).ok())
        .collect();
    let n_iters: u32 = 50;
    let cobrust_med = time_median(n_iters, 5, || {
        for bytes in &pre_packed {
            let _ = unpack(bytes);
        }
    });
    let cobrust_per_op = (cobrust_med / pre_packed.len() as u64).max(1);

    let result_json = json!({
        "library": "msgpack",
        "function": "unpack",
        "commit": short_commit_sha(),
        "cobrust_ns_per_op": cobrust_per_op,
        "n_inputs": pre_packed.len() as u32,
        "n_iters": n_iters,
    });
    let dir = workspace_target_dir()
        .join("cobrust-bench")
        .join("msgpack")
        .join(short_commit_sha());
    std::fs::create_dir_all(&dir).expect("mkdir bench dir");
    let path = dir.join("unpack_report.json");
    std::fs::write(&path, serde_json::to_string_pretty(&result_json).unwrap())
        .expect("write report");
    eprintln!("unpack bench at {}", path.display());
}
