{
  "name": "cobrust-language-support",
  "displayName": "Cobrust Language Support",
  "description": "Syntax highlighting, bracket matching, and comment toggle for the Cobrust programming language (.cb files).",
  "version": "0.1.0",
  "publisher": "cobrust",
  "license": "Apache-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobrust-lang/cobrust"
  },
  "bugs": {
    "url": "https://github.com/cobrust-lang/cobrust/issues"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "cobrust",
    "cb",
    "language",
    "syntax highlighting"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "cobrust",
        "aliases": [
          "Cobrust",
          "cobrust",
          "cb"
        ],
        "extensions": [
          ".cb"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "cobrust",
        "scopeName": "source.cobrust",
        "path": "./syntaxes/cobrust.tmLanguage.json"
      }
    ]
  }
}
