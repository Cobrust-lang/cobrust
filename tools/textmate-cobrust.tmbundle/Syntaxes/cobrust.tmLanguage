<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>name</key>
  <string>Cobrust</string>
  <key>scopeName</key>
  <string>source.cobrust</string>
  <key>fileTypes</key>
  <array>
    <string>cb</string>
  </array>
  <key>comment</key>
  <string>TextMate grammar for Cobrust — derived from tools/vscode-extension/syntaxes/cobrust.tmLanguage.json. Keywords sourced from crates/cobrust-frontend/src/token.rs.</string>
  <key>uuid</key>
  <string>A3F1B2C4-D5E6-7890-A1B2-C3D4E5F67890</string>
  <key>patterns</key>
  <array>
    <dict>
      <key>include</key>
      <string>#comments</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#fstrings</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#strings</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#numbers</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#keywords_control</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#keywords_declaration</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#keywords_operator</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#keywords_literal</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#types_builtin</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#types_primitive</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#decorators</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#function_def</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#function_call</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#operators</string>
    </dict>
  </array>
  <key>repository</key>
  <dict>
    <key>comments</key>
    <dict>
      <key>name</key>
      <string>comment.line.number-sign.cobrust</string>
      <key>match</key>
      <string>#.*$</string>
    </dict>
    <key>fstrings</key>
    <dict>
      <key>name</key>
      <string>string.interpolated.cobrust</string>
      <key>begin</key>
      <string>\b([fF]|[rR][fF]|[fF][rR])("""|'''|"|')</string>
      <key>beginCaptures</key>
      <dict>
        <key>1</key>
        <dict>
          <key>name</key>
          <string>storage.type.string.cobrust</string>
        </dict>
        <key>2</key>
        <dict>
          <key>name</key>
          <string>punctuation.definition.string.begin.cobrust</string>
        </dict>
      </dict>
      <key>end</key>
      <string>(\2)</string>
      <key>endCaptures</key>
      <dict>
        <key>1</key>
        <dict>
          <key>name</key>
          <string>punctuation.definition.string.end.cobrust</string>
        </dict>
      </dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>include</key>
          <string>#string_escapes</string>
        </dict>
      </array>
    </dict>
    <key>strings</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>string.quoted.triple.cobrust</string>
          <key>begin</key>
          <string>"""</string>
          <key>end</key>
          <string>"""</string>
          <key>patterns</key>
          <array>
            <dict>
              <key>include</key>
              <string>#string_escapes</string>
            </dict>
          </array>
        </dict>
        <dict>
          <key>name</key>
          <string>string.quoted.triple.cobrust</string>
          <key>begin</key>
          <string>'''</string>
          <key>end</key>
          <string>'''</string>
          <key>patterns</key>
          <array>
            <dict>
              <key>include</key>
              <string>#string_escapes</string>
            </dict>
          </array>
        </dict>
        <dict>
          <key>name</key>
          <string>string.quoted.double.cobrust</string>
          <key>begin</key>
          <string>"</string>
          <key>end</key>
          <string>"</string>
          <key>patterns</key>
          <array>
            <dict>
              <key>include</key>
              <string>#string_escapes</string>
            </dict>
          </array>
        </dict>
        <dict>
          <key>name</key>
          <string>string.quoted.single.cobrust</string>
          <key>begin</key>
          <string>'</string>
          <key>end</key>
          <string>'</string>
          <key>patterns</key>
          <array>
            <dict>
              <key>include</key>
              <string>#string_escapes</string>
            </dict>
          </array>
        </dict>
      </array>
    </dict>
    <key>string_escapes</key>
    <dict>
      <key>name</key>
      <string>constant.character.escape.cobrust</string>
      <key>match</key>
      <string>\\(\\|[abfnrtvz"']|\n|0|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4})</string>
    </dict>
    <key>numbers</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>constant.numeric.hex.cobrust</string>
          <key>match</key>
          <string>\b0[xX][0-9A-Fa-f][0-9A-Fa-f_]*\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>constant.numeric.binary.cobrust</string>
          <key>match</key>
          <string>\b0[bB][01][01_]*\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>constant.numeric.octal.cobrust</string>
          <key>match</key>
          <string>\b0[oO][0-7][0-7_]*\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>constant.numeric.float.cobrust</string>
          <key>match</key>
          <string>\b[0-9][0-9_]*(\.[0-9][0-9_]*)?([eE][+-]?[0-9][0-9_]*)?[jJ]?\b</string>
        </dict>
      </array>
    </dict>
    <key>keywords_control</key>
    <dict>
      <key>name</key>
      <string>keyword.control.cobrust</string>
      <key>match</key>
      <string>\b(if|elif|else|while|for|match|case|return|break|continue|pass|try|except|finally|raise|with|yield|await)\b</string>
    </dict>
    <key>keywords_declaration</key>
    <dict>
      <key>name</key>
      <string>keyword.declaration.cobrust</string>
      <key>match</key>
      <string>\b(fn|let|class|lambda|type)\b</string>
    </dict>
    <key>keywords_operator</key>
    <dict>
      <key>name</key>
      <string>keyword.operator.word.cobrust</string>
      <key>match</key>
      <string>\b(and|or|not|in|is|as|from|import)\b</string>
    </dict>
    <key>keywords_literal</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>constant.language.true.cobrust</string>
          <key>match</key>
          <string>\bTrue\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>constant.language.false.cobrust</string>
          <key>match</key>
          <string>\bFalse\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>constant.language.null.cobrust</string>
          <key>match</key>
          <string>\bNone\b</string>
        </dict>
      </array>
    </dict>
    <key>types_builtin</key>
    <dict>
      <key>name</key>
      <string>support.type.cobrust</string>
      <key>match</key>
      <string>\b(List|Dict|Set|Option|Result|Tuple)\b</string>
    </dict>
    <key>types_primitive</key>
    <dict>
      <key>name</key>
      <string>storage.type.cobrust</string>
      <key>match</key>
      <string>\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|str|bytes|isize|usize)\b</string>
    </dict>
    <key>decorators</key>
    <dict>
      <key>name</key>
      <string>meta.decorator.cobrust</string>
      <key>match</key>
      <string>(@)([a-zA-Z_][a-zA-Z0-9_]*(\.[a-zA-Z_][a-zA-Z0-9_]*)*)</string>
      <key>captures</key>
      <dict>
        <key>1</key>
        <dict>
          <key>name</key>
          <string>punctuation.decorator.cobrust</string>
        </dict>
        <key>2</key>
        <dict>
          <key>name</key>
          <string>entity.name.function.decorator.cobrust</string>
        </dict>
      </dict>
    </dict>
    <key>function_def</key>
    <dict>
      <key>name</key>
      <string>meta.function.cobrust</string>
      <key>match</key>
      <string>\b(fn)\s+([a-zA-Z_][a-zA-Z0-9_]*)</string>
      <key>captures</key>
      <dict>
        <key>1</key>
        <dict>
          <key>name</key>
          <string>keyword.declaration.cobrust</string>
        </dict>
        <key>2</key>
        <dict>
          <key>name</key>
          <string>entity.name.function.cobrust</string>
        </dict>
      </dict>
    </dict>
    <key>function_call</key>
    <dict>
      <key>name</key>
      <string>meta.function-call.cobrust</string>
      <key>match</key>
      <string>\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\s*\()</string>
      <key>captures</key>
      <dict>
        <key>1</key>
        <dict>
          <key>name</key>
          <string>entity.name.function.cobrust</string>
        </dict>
      </dict>
    </dict>
    <key>operators</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>keyword.operator.assignment.augmented.cobrust</string>
          <key>match</key>
          <string>(\+=|-=|\*\*=|\*=|//=|/=|%=|&amp;=|\|=|\^=|&lt;&lt;=|&gt;&gt;=)</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.comparison.cobrust</string>
          <key>match</key>
          <string>(==|!=|&lt;=|&gt;=|&lt;|&gt;)</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.assignment.cobrust</string>
          <key>match</key>
          <string>(:=|=)</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.arrow.cobrust</string>
          <key>match</key>
          <string>-&gt;</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.arithmetic.cobrust</string>
          <key>match</key>
          <string>(\*\*|//|[+\-*/%])</string>
        </dict>
      </array>
    </dict>
  </dict>
</dict>
</plist>
